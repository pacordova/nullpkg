gdbm=(){tag=1.23 src=gnu:%s-$tag.tar.gz μ=Configure flags=('disable-static' $dirflags)}
glib=(){tag=2.70.4 src=gnome:%s μ=Meson flags=('tests=false')}
json=(){src='http://s3.amazonaws.com/json-c_releases/releases/json-c-0.15.tar.gz' μ=CMake}
libcap=(){tag=v1.2.62 src=kernel:libs/libcap/%s μ=GMake}
libeudev=(){tag=v3.2.11 src=gh:eudev-project/eudev μ=Autotools flags=('disable-static')}
libexpat=(){tag=R_2_4_2 src=gh:libexpat/%s μ=(eval 'cd expat;CMake')}
libffi=(){tag=v3.4.2 src=gh:%s/%s μ=Autotools flags=('disable-static')}
libfuse=(){tag=fuse-3.10.5 src=gh:%s/%s μ=Meson}
libjpeg-turbo=(){src='https://downloads.sourceforge.net/libjpeg-turbo/libjpeg-turbo-2.1.2.tar.gz' μ=CMake}
libnsl=(){tag=v2.0.0 src=gh:thkukuk/%s μ=Autotools flags=('disable-static')}
libpng=(){src='https://downloads.sourceforge.net/libpng/libpng-1.6.37.tar.xz' μ=Configure flags=($dirflags 'disable-static')}
libpsl=(){tag=0.21.1 src=gh:rockdaboot/%s μ=Meson}
libsigsegv=(){src='http://ftp.gnu.org/gnu/libsigsegv/libsigsegv-2.14.tar.gz' μ=Configure flags=($dirflags 'disable-static' 'enable-shared')}
libtiff=(){tag=v4.3.0 src=gitlab:%s/%s μ=Autotools flags=('disable-static')}
libtirpc=(){src='http://downloads.sourceforge.net/libtirpc/libtirpc-1.3.2.tar.bz2' μ=Configure flags=($dirflags 'disable-gssapi' 'disable-static')}
libunwind=(){tag=v1.6.2 src=gh:%s/%s μ=Autotools flags=('disable-static')}
libusb=(){src='https://github.com/libusb/libusb/releases/download/v1.0.25/libusb-1.0.25.tar.bz2' μ=Configure flags=($dirflags 'disable-static')}
lvm=(){src='http://sourceware.org/ftp/lvm2/LVM2.2.03.15.tgz' μ=Configure flags=($dirflags 'disable-static')}
ncurses=(){tag=6.3 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-shared' 'without-normal' 'with-cxx=no' 'disable-static' 'with-termlib=tinfo')}
openssh=(){tag=V_8_8 src=gh:%s/%s-portable μ=Autotools flags=('disable-static')}
pcre2=(){tag=pcre2-10.39 src=gh:philiphazel/%s μ=CMake flags=('PCRE2_BUILD_PCRE2_16=ON' 'PCRE2_BUILD_PCRE2_32=ON' 'PCRE2_BUILD_TESTS=OFF' 'PCRE2_BUILD_PCRE2GREP=OFF')}
pcre=(){src='http://sourceforge.net/projects/pcre/files/pcre/8.45/pcre-8.45.tar.bz2' flags=('PCRE_SUPPORT_UNICODE_PROPERTIES=ON' 'PCRE_SUPPORT_JIT=ON' 'PCRE_BUILD_PCREGREP=OFF' 'PCRE_BUILD_TESTS=OFF') μ=CMake}
popt=(){tag=popt-1.18-release src=gh:rpm-software-management/%s μ=Autotools flags=('disable-static')}
readline=(){tag=8.1.2 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-curses' 'disable-static')}
####
pkg-config=(){src='https://pkgconfig.freedesktop.org/releases/pkg-config-0.29.2.tar.gz' μ=Configure flags=($dirflags 'with-internal-glib')}
libunistring=(){tag=1.0 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
libaio=(){src='https://ftp.debian.org/debian/pool/main/liba/libaio/libaio_0.3.112.orig.tar.xz' μ=GMake flags=('libdir=/usr/lib64')}


