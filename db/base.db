#!/bin/rc

################
# FROM SCRATCH #
################


############
# Layer:01 #
############
# kernel headers before glibc
glibc=(){tag=2.35 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
gcc=(){tag=11.2.0 src=gnu:%s-$tag/%s-$tag.tar.gz flags=($dirflags 'enable-multilib=no' 'enable-languages=c c++ fortran' 'disable-nls' 'disable-bootstrap' 'enable-shared') ﾎｼ=Configure}


############
# Layer:02 #
############

# layer02 utils
binutils=(){tag=2.38 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'enable-deterministic-archives')}
make=(){tag=4.3 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'with-guile=no')}
bash=(){tag=5.1.16 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'with-bash-malloc=no')}
coreutils=(){tag=9.0 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
grep=(){tag=3.7 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
ed=(){tag=1.4 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
sed=(){tag=4.8 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}

# net
libressl=(){tag=v3.5.2 src=gh:libressl-portable/portable ﾎｼ=Autotools}
openssl=(){tag=OpenSSL_1_1_1n src=gh:%s/%s ﾎｼ=GMake}
curl=(){tag=curl-7_81_0 src=gh:%s/%s ﾎｼ=CMake flags=('ENABLE_THREADED_RESOLVER=ON')}
git=(){tag=v2.35.1 src=gh:%s/%s ﾎｼ=Autotools flags=('with-gitconfig=/etc/gitconfig')}
rc=(){tag=master src=gh:pacordova/rc ﾎｼ=GMake}

# compression
zlib=(){tag=v1.2.11 src=gh:madler/%s ﾎｼ=Configure flags=('libdir='$LIBDIR)}
gzip=(){tag=1.11 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
tar=(){tag=1.34 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
xz=(){tag=v5.2.5 src=gh:xz-mirror/%s ﾎｼ=CMake}
bzip2=(){src='http://sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz' ﾎｼ=GMake flags=$dirflags}
zstd=(){tag=v1.5.2 src=gh:facebook/zstd ﾎｼ=GMake}

# need perl modules XML::Parser, Locale::gettext, libtool, intltool + circular
flex=(){tag=v2.6.4 src=gh:westes/flex ﾎｼ=Autotools}


############
# Layer:03 #
############
# bootstrap gawk with nawk: gh:onetrueawk/awk, glibc needs gawk
gawk=(){tag=5.1.0 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'with-readline=no')}

# manually configure
perl=(){tag=v5.34.1 src=gh:perl/perl5 ﾎｼ=GMake}

m4=(){tag=1.4.19 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
autoconf=(){tag=2.69 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
automake=(){tag=1.16.5 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}

texinfo=(){tag=6.8 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
bison=(){tag=3.8.2 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
bc=(){tag=1.07.1 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}

cmake=(){tag=v3.22.2 src=gh:kitware/%s ﾎｼ=Configure}

diffutils=(){tag=3.8 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
findutils=(){tag=4.9.0 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
patch=(){tag=2.7.6 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}

gettext=(){tag=0.21 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
help2man=(){tag=1.49.2 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
#autobuild=(){src='http://download.savannah.gnu.org/releases/autobuild/autobuild-5.3.tar.gz' ﾎｼ=Configure flags=$dirflags}
libtool=(){tag=2.4.6 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}

# python
python=(){tag=v3.9.10 src=gh:python/cpython ﾎｼ=Configure flags=($dirflags 'with-platlibdir=lib64' 'without-ensurepip' 'enable-optimizations' 'enable-shared')}
python-setuptools=(){tag=v62.1.0 src=gh:pypa/setuptools ﾎｼ=Python}
python-pip=(){tag=22.0.4 src=gh:pypa/pip ﾎｼ=Python}
# alternatively use pip for meson/ninja
meson=(){tag=0.62.1 src=gh:mesonbuild/%s ﾎｼ=Python}
ninja=(){tag=v1.10.2 src=gh:ninja-build/%s ﾎｼ=CMake}


############
# Layer:04 #
############
less=(){tag=590 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
which=(){tag=2.21 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
time=(){tag=1.9 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
vim=(){tag=v8.2.4383 src=gh:%s/%s ﾎｼ=Configure flags=('disable-gui' 'without-x')}
e2fsprogs=(){tag=v1.46.5 src=kernel:fs/ext2/%s ﾎｼ=Configure flags=($dirflags 'enable-elf-shlibs')}
util-linux=(){tag=v2.37.4 src=kernel:utils/%s/%s}
shadow=(){tag=v4.11.1 src=gh:shadow-maint/%s ﾎｼ=Autotools flags=('without-nls')}
sudo=(){src='https://www.sudo.ws/dist/sudo-1.9.9.tar.gz' ﾎｼ=Configure flags=$dirflags}

dbus=(){tag=dbus-1.13.22 src=freedesktop:dbus/%s ﾎｼ=CMake flags=('with-systemduserunitdir=no')}

# connman < libnftnl libmnl
iptables=(){tag=1.8.7 src=netfilter:%s/%s-$tag.tar.bz2 ﾎｼ=Configure}
# connman needs -lncurses
connman=(){tag=1.41 src=kernel:network/%s/%s ﾎｼ=Autotools flags=('with-systemdunitdir=no')}

# elogind < gperf
elogind=(){tag=v246.10 src=gh:elogind/%s ﾎｼ=Meson}

# efibootmgr
mandoc=(){src='https://mandoc.bsd.lv/snapshots/mandoc-1.14.6.tar.gz' ﾎｼ=Configure}
efivar=(){tag=38 src=gh:rhboot/efivar ﾎｼ=GMake}
efibootmgr=(){tag=main src=gh:rhboot/efibootmgr ﾎｼ=GMake}


#############
# GNU Extra #
#############
gperf=(){tag=3.1 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
gmp=(){tag=6.2.1 src=gnu:%s-$tag.tar.xz ﾎｼ=Configure flags=$dirflags}
mpc=(){tag=1.2.1 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
#libiconv=(){tag=1.16 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'with-pic=no' 'enable-static=yes' 'enable-shared=no' 'enable-relocatable')}
gdb=(){tag=11.1 src=gnu:%s-$tag.tar.xz ﾎｼ=Autotools flags=($dirflags 'with-guile=no' 'with-system-readline' 'with-python=no')}
guile=(){tag=3.0.7 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=$dirflags}
nettle=(){tag=3.7 src=gnu:%s-$tag.tar.gz ﾎｼ=Configure flags=($dirflags 'enable-shared')}
