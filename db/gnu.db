#!/usr/bin/env rc

# make <-> make -> autoconf, automake
make='src=mirrors.kernel.org/gnu/make/make-4.3.tar.gz mk=Configure flags=(with-guile=no enable-nls=no)'

#build before rebuilding reset of system
m4='tag=1.4.19 src=gnu:%s.tar.gz mk=Configure'
libiconv='tag=1.16 src=gnu:%s.tar.gz mk=Configure'
autoconf='tag=2.71 src=gnu:%s.tar.gz mk=Configure'
automake='tag=1.16.5 src=gnu:%s.tar.gz mk=Configure'
texinfo='tag=6.8 src=gnu:%s.tar.gz mk=Configure'
libiconv='tag=1.16 src=gnu:%s.tar.gz mk=Configure'
gettext='tag=0.21 src=gnu:%s.tar.xz mk=Configure'

#for kernel
bison='tag=3.8.2 src=gnu:%s.tar.gz mk=Configure'
bc='tag=1.07 src=gnu:%s.tar.gz mk=Configure'

#utils
binutils='tag=2.37 src=gnu:%s.tar.gz mk=Configure'
coreutils='tag=9.0 src=gnu:%s.tar.gz mk=Configure'
diffutils='tag=3.8 src=gnu:%s.tar.xz mk=Configure'
findutils='tag=4.8.0 src=gnu:%s.tar.xz mk=Configure'

#toolchain
grep='tag=3.7 src=gnu:%s.tar.xz mk=Configure'
bash='tag=5.1.8 src=gnu:%s.tar.gz mk=Configure flags=(without-libiconv-prefix)'
gawk='tag=5.1.1 src=gnu:%s.tar.gz mk=Configure flags=(with-readline=no)'
gzip='tag=1.11 src=gnu:%s.tar.gz mk=Configure'
tar='tag=1.34 src=gnu:%s.tar.gz mk=Configure'
patch='tag=2.7.6 src=gnu:%s.tar.gz mk=Configure'
sed='tag=4.8 src=gnu:%s.tar.gz mk=Configure'

#termstuff
ncurses='tag=6.0 src=gnu:%s.tar.gz mk=Configure flags=(with-shared with-cxx=no)'
readline='tag=8.0 src=gnu:%s.tar.gz mk=Configure CFLAGS=($CFLAGS -lncurses) flags=(with-curses disable-static)'
less='tag=590 src=gnu:%s.tar.gz mk=Configure'

#debugger
gdb='tag=11.1 src=gnu:%s.tar.xz mk=Configure flags=(with-^(guile=no system-readline python=no))'

#mpc for gcc
#gmp='tag=6.2.1 src=gnu:%s.tar.xz mk=Configure'
#mpc='tag=1.2.1 src=gnu:%s.tar.gz mk=Configure'

#big kahuna
glibc='tag=2.34 src=gnu:%s.tar.gz mk=Configure'
gcc='tag=11.2.0 src=gnu:%s.tar.gz flags=(enable-multilib=no) mk=Configure'

#impossible to build libtool and deps...
help2man='tag=1.48.5 src=gnu:%s.tar.xz mk=Configure'
autobuild='src=download.savannah.gnu.org/releases/autobuild/autobuild-5.3.tar.gz mk=Configure'
libtool='tag=2.4.6 src=gnu:%s.tar.gz mk=λ;fn λ{sed -i configure.ac -e ''s|2.62|[2.64]|'';./bootstrap --force;Configure}'

# misc
gperf='tag=3.1 src=gnu:%s.tar.gz mk=Configure'
guile='src=gnu:%s.tar.gz tag=3.0.7 mk=Configure'
gmp='tag=6.2.1 src=gnu:%s.tar.xz mk=Configure'
nettle='tag=3.7 src=gnu:%s.tar.gz mk=Configure flags=(enable-shared)'
gnutls='src=www.gnupg.org/ftp/gcrypt/gnutls/v3.6/%s-3.6.16.tar.xz mk=Configure flags=(with-included-libtasn1)'
