#!/bin/rc

cd /usr/nullpkg && make
. /etc/make.conf


. functions.rc

cd cache

ldconfig && /usr/nullpkg/misc/locale.rc

tar -xhf sources.tar.xz
mv sources/* .

__emerge python python-setuptools python-pip;
sleep 3 &&
python3 -m pip install meson &&
python3 -m pip install docutils

__emerge $LIB
__emerge $BASE
__emerge $SYS
