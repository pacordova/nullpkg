#mutter
zenity(){tag=3.41.0 src=gnome:%s μ=Meson}
mutter(){tag=40.4 src=gnome:%s ^=false}

#gala
#9eca0bd release segfaults
gala(){buildtype=debug src=gh:elementary/%s μ=Meson flags=('systemd=false')'

#bug?
cairo(){src=freedesktop:%s/%s μ=Meson flags=('spectre=disabled')}
pango(){tag=1.48.10 src=gnome:%s μ=Meson}
