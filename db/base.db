#!/bin/rc

########
# base #
########
gcc=(){tag=11.2.0 src=gnu:%s-$tag/%s-$tag.tar.xz flags=($dirflags 'disable-multilib' 'enable-languages=c c++ fortran' 'disable-nls' 'disable-bootstrap' 'enable-shared') Œº=Configure}
bash=(){tag=5.1.16 src=gnu:%s-$tag.tar.gz Œº=Configure flags=($dirflags 'with-bash-malloc=no')}
bc=(){tag=1.07.1 src=gnu:%s-$tag.tar.gz Œº=Configure flags=$dirflags}
binutils=(){tag=2.38 src=gnu:%s-$tag.tar.xz Œº=Configure flags=($dirflags 'enable-deterministic-archives')}
bison=(){tag=3.8.2 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
coreutils=(){tag=9.0 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
diffutils=(){tag=3.8 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
ed=(){tag=1.4 src=gnu:%s-$tag.tar.gz Œº=Configure flags=$dirflags}
findutils=(){tag=4.9.0 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
flex=(){tag=v2.6.4 src=gh:westes/flex Œº=Autotools}
gawk=(){tag=5.1.0 src=gnu:%s-$tag.tar.xz Œº=Configure flags=($dirflags 'with-readline=no')}
grep=(){tag=3.7 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
m4=(){tag=1.4.19 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
make=(){tag=4.3 src=gnu:%s-$tag.tar.gz Œº=Configure flags=($dirflags 'with-guile=no')}
patch=(){tag=2.7.6 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
rc=(){tag=master src=gh:pacordova/rc Œº=GMake}
sed=(){tag=4.8 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
sharutils=(){tag=4.15.2 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
time=(){tag=1.9 src=gnu:%s-$tag.tar.gz Œº=Configure flags=$dirflags}
vim=(){tag=v8.2.4383 src=gh:%s/%s Œº=Configure flags=($dirflags 'disable-gui' 'without-x' 'disable-nls' 'disable-canberra')}

# compression
zlib=(){tag=v1.2.11 src=gh:madler/%s Œº=Configure flags=('libdir='$LIBDIR)}
bzip2=(){tag=master src=gitlab:%s/%s Œº=CMake flags=('ENABLE_SHARED_LIB=ON' 'ENABLE_STATIC_LIB=OFF')}
gzip=(){tag=1.11 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
tar=(){tag=1.34 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
unzip=(){tag=60 src=https://downloads.sourceforge.net/infozip/%s$tag.tar.gz Œº=GMake flags=('--file=unix/Makefile' 'prefix='$destdir/$PREFIX 'generic')}
xz=(){tag=5.2.5 src=https://tukaani.org/%s/%s-$tag.tar.xz Œº=Configure flags=$dirflags}
zstd=(){tag=v1.5.2 src=gh:facebook/zstd Œº=GMake}

# network
libressl=(){tag=3.5.3 src=https://ftp.openbsd.org/pub/OpenBSD/LibreSSL/%s-$tag.tar.gz Œº=Configure flags=$dirflags}
curl=(){tag=7.81.0 src=https://curl.se/download/%s-$tag.tar.xz Œº=Configure flags=($dirflags 'disable-static' 'with-openssl' 'with-ca-path=/etc/ssl/certs' 'with-ca-bundle=/etc/ssl/certs/ca-certificates.crt' 'enable-threaded-resolver')}
git=(){tag=v2.35.1 src=kernel:%s/%s Œº=Autotools flags=('with-gitconfig=/etc/gitconfig')}

#######
# dev #
#######
autoconf=(){tag=2.69 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
automake=(){tag=1.15.1 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
cmake=(){src='https://cmake.org/files/v3.22/cmake-3.22.2.tar.gz' Œº=Configure}
gettext=(){tag=0.21 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
help2man=(){tag=1.49.2 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
libtool=(){tag=2.4.6 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}
ninja=(){tag=v1.10.2 src=gh:ninja-build/%s Œº=CMake}
texinfo=(){tag=6.8 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags}

# python
python=(){tag=v3.9.13 src=gh:python/cpython Œº=Configure flags=($dirflags 'with-platlibdir=lib64' 'without-ensurepip' 'enable-optimizations' 'enable-shared')}
python-setuptools=(){tag=v62.3.2 src=gh:pypa/setuptools Œº=Python}
python-pip=(){tag=22.1.2 src=gh:pypa/pip Œº=Python}

#######
# sys #
#######
shadow=(){tag=v4.11.1 src=gh:shadow-maint/%s Œº=Autotools flags=('without-nls')}
dbus=(){src='https://dbus.freedesktop.org/releases/dbus/dbus-1.12.20.tar.gz' Œº=Configure flags=($dirflags 'enable-user-session' 'disable-static' 'with-systemduserunitdir=no' 'with-systemdsystemunitdir=no' 'with-console-auth-dir=/run/console' 'with-system-pid-file=/run/dbus/pid' 'with-system-socket=/run/dbus/system_bus_socket')}
e2fsprogs=(){tag=v1.46.5 src=kernel:fs/ext2/%s Œº=Configure flags=($dirflags 'enable-elf-shlibs')}
inetutils=(){tag=2.2 src=gnu:%s-$tag.tar.xz Œº=Configure flags=$dirflags CFLAGS=$CFLAGS^'-ltinfo '}
kmod=(){tag=v29 src=kernel:utils/kernel/%s/%s Œº=Autotools flags=('disable-manpages')}
less=(){tag=590 src=gnu:%s-$tag.tar.gz Œº=Configure flags=$dirflags}
lvm=(){src='https://sourceware.org/ftp/lvm2/LVM2.2.03.15.tgz' Œº=Configure flags=($dirflags 'disable-static')}
mandoc=(){tag=1.14.6 src=https://mandoc.bsd.lv/snapshots/%s-$tag.tar.gz Œº=Configure}
openssh=(){src='https://ftp.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-8.8p1.tar.gz' Œº=Configure flags=($dirflags 'disable-static')}
procps-ng=(){tag=3.3.17 src=https://sourceforge.net/projects/%s/files/Production/%s-$tag.tar.xz Œº=Configure flags=($dirflags 'disable-kill') CFLAGS=$CFLAGS^'-ltinfo '}
sudo=(){tag=1.9.9 src=https://www.sudo.ws/dist/%s-$tag.tar.gz Œº=Configure flags=$dirflags}
sysvinit=(){tag=3.01 src=https://download.savannah.gnu.org/releases/sysvinit/sysvinit-$tag.tar.xz Œº=GMake flags=(ROOT=$destdir)}
util-linux=(){tag=v2.37.4 src=kernel:utils/%s/%s Œº=Autotools flags=($dirflags 'disable-chfn-chsh' 'disable-login' 'disable-nologin' 'disable-su' 'disable-setpriv' 'disable-runuser' 'disable-pylibmount' 'disable-static' 'without-python' 'without-systemd' 'without-systemdsystemunitdir')}
which=(){tag=2.21 src=gnu:%s-$tag.tar.gz Œº=Configure flags=$dirflags}

# connman
libmnl=(){tag=1.0.4 src=netfilter:%s/%s-$tag.tar.bz2 Œº=Configure flags=$dirflags}
libnftnl=(){tag=1.2.1 src=netfilter:%s/%s-$tag.tar.bz2 Œº=Configure flags=$dirflags}
iptables=(){tag=1.8.7 src=netfilter:%s/%s-$tag.tar.bz2 Œº=Configure flags=($dirflags 'enable-shared')}
nettle=(){tag=3.7 src=gnu:%s-$tag.tar.gz Œº=Configure flags=($dirflags 'enable-shared')}
gnutls=(){src='https://www.gnupg.org/ftp/gcrypt/gnutls/v3.6/gnutls-3.6.16.tar.xz' Œº=Configure flags=('with-included-libtasn1' 'without-p11-kit' 'enable-shared' $dirflags)}
connman=(){tag=1.41 src=kernel:network/%s/%s Œº=Autotools flags=('with-systemdunitdir=no') CFLAGS=$CFLAGS^'-lncurses '}

# efibootmgr
efivar=(){tag=38 src=gh:rhboot/efivar Œº=GMake}
efibootmgr=(){tag=main src=gh:rhboot/efibootmgr Œº=GMake EFIDIR=/boot}

# syslogs
libestr=(){tag=v0.1.11 src=gh:rsyslog/%s Œº=Autotools flags=('disable-static')}
libfastjson=(){tag=v0.99.9 src=gh:rsyslog/%s Œº=Autotools flags=('disable-static')}
rsyslog=(){tag=v8.2204.1 src=gh:%s/%s Œº=Autotools flags=('disable-libgcrypt' 'disable-generate-man-pages')}
