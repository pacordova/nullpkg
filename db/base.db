#!/bin/rc

########
# base #
########
autoconf=(){tag=2.69 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
automake=(){tag=1.15.1 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
bash=(){tag=5.1.16 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-bash-malloc=no')}
bc=(){tag=1.07.1 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
binutils=(){tag=2.38 src=gnu:%s-$tag.tar.xz μ=Configure flags=($dirflags 'enable-deterministic-archives')}
bison=(){tag=3.8.2 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
cmake=(){src='https://cmake.org/files/v3.22/cmake-3.22.2.tar.gz' μ=Configure}
coreutils=(){tag=9.0 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
curl=(){tag=7.81.0 src=https://curl.se/download/%s-$tag.tar.xz μ=Configure flags=($dirflags 'disable-static' 'with-openssl' 'with-ca-path=/etc/ssl/certs' 'with-ca-bundle=/etc/ssl/certs/ca-certificates.crt' 'enable-threaded-resolver')}
diffutils=(){tag=3.8 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
ed=(){tag=1.4 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
file=(){tag=5.41 src=https://astron.com/pub/%s/%s-$tag.tar.gz μ=Configure flags=$dirflags}
findutils=(){tag=4.9.0 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
flex=(){tag=v2.6.4 src=gh:westes/flex μ=Autotools}
gawk=(){tag=5.1.0 src=gnu:%s-$tag.tar.xz μ=Configure flags=($dirflags 'with-readline=no')}
gcc=(){tag=11.2.0 src=gnu:%s-$tag/%s-$tag.tar.xz flags=($dirflags 'disable-multilib' 'enable-languages=c c++ fortran' 'disable-nls' 'disable-bootstrap' 'enable-shared') μ=Configure}
gettext=(){tag=0.21 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
git=(){tag=v2.35.1 src=kernel:%s/%s μ=Autotools flags=('with-gitconfig=/etc/gitconfig')}
grep=(){tag=3.7 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
help2man=(){tag=1.49.2 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
less=(){tag=590 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
libtool=(){tag=2.4.6 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
m4=(){tag=1.4.19 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
make=(){tag=4.3 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-guile=no')}
ninja=(){tag=v1.10.2 src=gh:ninja-build/%s μ=CMake}
patch=(){tag=2.7.6 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
rc=(){tag=master src=gh:pacordova/rc μ=GMake}
sed=(){tag=4.8 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
sharutils=(){tag=4.15.2 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
texinfo=(){tag=6.8 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
vim=(){tag=v8.2.4383 src=gh:%s/%s μ=Configure flags=($dirflags 'disable-gui' 'without-x' 'disable-nls' 'disable-canberra')}
which=(){tag=2.21 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

# compression
zlib=(){tag=v1.2.11 src=gh:madler/%s μ=Configure flags=('libdir='$LIBDIR)}
bzip2=(){tag=master src=gitlab:%s/%s μ=Meson}
gzip=(){tag=1.11 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
tar=(){tag=1.34 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
unzip=(){tag=60 src=https://downloads.sourceforge.net/infozip/%s$tag.tar.gz μ=GMake flags=('--file=unix/Makefile' 'prefix='$destdir/$PREFIX 'generic')}
xz=(){tag=5.2.5 src=https://tukaani.org/%s/%s-$tag.tar.xz μ=Configure flags=$dirflags}
zstd=(){tag=v1.5.2 src=gh:facebook/zstd μ=GMake}

# python
python=(){tag=v3.10.5 src=gh:python/cpython μ=Configure flags=($dirflags 'with-platlibdir=lib64' 'without-ensurepip' 'enable-optimizations' 'enable-shared')}
python-setuptools=(){tag=v57.5.0 src=gh:pypa/setuptools μ=Python}
python-pip=(){tag=22.1.2 src=gh:pypa/pip μ=Python}
meson=(){tag=0.59.4 src=gh:mesonbuild/%s μ=Python}


#######
# sys #
#######
e2fsprogs=(){tag=v1.46.5 src=kernel:fs/ext2/%s μ=Configure flags=($dirflags 'enable-elf-shlibs')}
inetutils=(){tag=2.2 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
kmod=(){tag=v29 src=kernel:utils/kernel/%s/%s μ=Autotools flags=('disable-manpages')}
procps-ng=(){tag=3.3.17 src=https://sourceforge.net/projects/%s/files/Production/%s-$tag.tar.xz μ=Configure flags=($dirflags 'disable-kill' 'without-ncurses')}
rsyslog=(){tag=v8.2204.1 src=gh:%s/%s μ=Autotools flags=('disable-libgcrypt' 'disable-generate-man-pages')}
shadow=(){tag=v4.11.1 src=gh:shadow-maint/%s μ=Autotools flags=('without-nls')}
sysvinit=(){tag=3.01 src=https://download.savannah.gnu.org/releases/sysvinit/sysvinit-$tag.tar.xz μ=GMake flags=(ROOT=$destdir)}
util-linux=(){tag=v2.37.4 src=kernel:utils/%s/%s μ=Autotools flags=($dirflags 'disable-chfn-chsh' 'disable-login' 'disable-nologin' 'disable-su' 'disable-setpriv' 'disable-runuser' 'disable-pylibmount' 'disable-static' 'without-python' 'without-systemd' 'without-systemdsystemunitdir')}

# extra system
acpid=(){tag=2.0.33 src=https://downloads.sourceforge.net/acpid2/%s-$tag.tar.xz μ=Configure flags=$dirflags}
cryptsetup=(){tag=v2.4.3 src=gitlab:%s/%s μ=Autotools flags=('disable-ssh-token')}
dbus=(){src='https://dbus.freedesktop.org/releases/dbus/dbus-1.12.20.tar.gz' μ=Configure flags=($dirflags 'enable-user-session' 'disable-static' 'with-systemduserunitdir=no' 'with-systemdsystemunitdir=no' 'with-console-auth-dir=/run/console' 'with-system-pid-file=/run/dbus/pid' 'with-system-socket=/run/dbus/system_bus_socket')}
dosfstools=(){tag=v4.2 src=gh:%s/%s μ=Autotools}
fcron=(){tag=3.2.1 src=http://fcron.free.fr/archives/%s-$tag.src.tar.gz μ=Configure flags=($dirflags 'without-sendmail')}
lm-sensors=(){tag=V3-6-0 src=gh:%s/%s μ=GMake flags=('LIBDIR=/usr/lib64')}
logrotate=(){tag=3.19.0 src=gh:%s/%s μ=Autotools}
lua=(){src='http://www.lua.org/ftp/lua-5.4.4.tar.gz' μ=GMake flags=('INSTALL_TOP='$destdir/$PREFIX 'INSTALL_LIB=$(INSTALL_TOP)/lib64' 'INSTALL_CMOD=$(INSTALL_LIB)/lua/$V')}
mandoc=(){tag=1.14.6 src=https://mandoc.bsd.lv/snapshots/%s-$tag.tar.gz μ=Configure}
nano=(){tag=6.3 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
openssh=(){src='https://ftp.openbsd.org/pub/OpenBSD/OpenSSH/portable/openssh-8.8p1.tar.gz' μ=Configure flags=($dirflags 'disable-static')}
parted=(){tag=3.5 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
pciutils=(){tag=v3.7.0 src=kernel:utils/%s/%s μ=GMake flags=('LIBDIR=/usr/lib64')}
rsync=(){tag=v3.2.3 src=gh:wayned/%s μ=Configure flags=('disable-lz4' 'disable-xxhash' 'disable-md2man')}
sqlite=(){src='https://sqlite.org/2022/sqlite-autoconf-3380400.tar.gz' μ=Autotools}
sudo=(){tag=1.9.9 src=https://www.sudo.ws/dist/%s-$tag.tar.gz μ=Configure flags=$dirflags}
tcsh=(){tag=6.24.00 src=https://astron.com/pub/%s/%s-$tag.tar.gz μ=Configure flags=$dirflags}
time=(){tag=1.9 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
tmux=(){tag=3.2 src=gh:%s/%s μ=Autotools}
xorriso=(){tag=1.5.4 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

# connman
glib=(){tag=2.70.4 src=gnome:%s μ=Meson flags=('tests=false')}
iptables=(){tag=1.8.7 src=netfilter:%s/%s-$tag.tar.bz2 μ=Configure flags=($dirflags 'enable-shared')}
nettle=(){tag=3.7 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'enable-shared')}
gnutls=(){src='https://www.gnupg.org/ftp/gcrypt/gnutls/v3.6/gnutls-3.6.16.tar.xz' μ=Configure flags=('with-included-libtasn1' 'without-p11-kit' 'enable-shared' $dirflags)}
connman=(){tag=1.41 src=kernel:network/%s/%s μ=Autotools flags=('with-systemdunitdir=no') LIBS='-ltinfo'}

# efibootmgr
efivar=(){tag=38 src=gh:rhboot/efivar μ=GMake}
efibootmgr=(){tag=main src=gh:rhboot/efibootmgr μ=GMake EFIDIR=/boot}
