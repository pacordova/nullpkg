#!/bin/rc

################
# FROM SCRATCH #
################


############
# Layer:01 #
############
# kernel headers before glibc
glibc=(){tag=2.35 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
gcc=(){tag=11.2.0 src=gnu:%s-$tag/%s-$tag.tar.gz flags=($dirflags 'enable-multilib=no' 'enable-languages=c c++ fortran' 'disable-nls' 'disable-bootstrap' 'enable-shared') μ=Configure}
# manually configure
perl=(){tag=v5.34.1 src=gh:perl/perl5 μ=GMake}


############
# Layer:02 #
############
# layer02 utils
binutils=(){tag=2.38 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'enable-deterministic-archives')}
make=(){tag=4.3 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-guile=no')}
bash=(){tag=5.1.16 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-bash-malloc=no')}
coreutils=(){tag=9.0 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
grep=(){tag=3.7 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
ed=(){tag=1.4 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
sed=(){tag=4.8 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

# net
libressl=(){tag=v3.5.2 src=gh:libressl-portable/portable μ=Autotools}
curl=(){tag=curl-7_81_0 src=gh:%s/%s μ=CMake flags=('ENABLE_THREADED_RESOLVER=ON')}
git=(){tag=v2.35.1 src=gh:%s/%s μ=Autotools flags=('with-gitconfig=/etc/gitconfig')}
rc=(){tag=master src=gh:pacordova/rc μ=GMake}

# compression
zlib=(){tag=v1.2.11 src=gh:madler/%s μ=Configure flags=('libdir='$LIBDIR)}
gzip=(){tag=1.11 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
tar=(){tag=1.34 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
xz=(){tag=v5.2.5 src=gh:xz-mirror/%s μ=CMake}
bzip2=(){src='http://sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz' μ=GMake flags=$dirflags}
zstd=(){tag=v1.5.2 src=gh:facebook/zstd μ=GMake}

# need perl modules XML::Parser, Locale::gettext, libtool, intltool + circular
flex=(){tag=v2.6.4 src=gh:westes/flex μ=Autotools}

# if new glibc, bootstrap gawk with nawk: gh:onetrueawk/awk, glibc needs gawk
gawk=(){tag=5.1.0 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-readline=no')}


############
# Layer:03 #
############
m4=(){tag=1.4.19 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
autoconf=(){tag=2.69 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
automake=(){tag=1.16.5 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

texinfo=(){tag=6.8 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
bison=(){tag=3.8.2 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
bc=(){tag=1.07.1 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

cmake=(){tag=v3.22.2 src=gh:kitware/%s μ=Configure}

diffutils=(){tag=3.8 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
findutils=(){tag=4.9.0 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
patch=(){tag=2.7.6 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}

gettext=(){tag=0.21 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
help2man=(){tag=1.49.2 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}
#autobuild=(){src='http://download.savannah.gnu.org/releases/autobuild/autobuild-5.3.tar.gz' μ=Configure flags=$dirflags}
libtool=(){tag=2.4.6 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
gmp=(){tag=6.2.1 src=gnu:%s-$tag.tar.xz μ=Configure flags=$dirflags}

# python
python=(){tag=v3.9.10 src=gh:python/cpython μ=Configure flags=($dirflags 'with-platlibdir=lib64' 'without-ensurepip' 'enable-optimizations' 'enable-shared')}
python-setuptools=(){tag=v62.1.0 src=gh:pypa/setuptools μ=Python}
python-pip=(){tag=22.0.4 src=gh:pypa/pip μ=Python}
# alternatively use pip for meson/ninja
meson=(){tag=0.62.1 src=gh:mesonbuild/%s μ=Python}
ninja=(){tag=v1.10.2 src=gh:ninja-build/%s μ=CMake}


############
# Layer:04 #
############
less=(){tag=590 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
which=(){tag=2.21 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
time=(){tag=1.9 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
vim=(){tag=v8.2.4383 src=gh:%s/%s μ=Configure flags=('disable-gui' 'without-x')}
e2fsprogs=(){tag=v1.46.5 src=kernel:fs/ext2/%s μ=Configure flags=($dirflags 'enable-elf-shlibs')}
util-linux=(){tag=v2.37.4 src=kernel:utils/%s/%s μ=Autotools flags=($dirflags 'disable-chfn-chsh' 'disable-login' 'disable-nologin' 'disable-su' 'disable-setpriv' 'disable-runuser' 'disable-pylibmount' 'disable-static' 'without-python' 'without-systemd' 'without-systemdsystemunitdir')}
shadow=(){tag=v4.11.1 src=gh:shadow-maint/%s μ=Autotools flags=('without-nls')}
sudo=(){src='https://www.sudo.ws/dist/sudo-1.9.9.tar.gz' μ=Configure flags=$dirflags}
lvm=(){src='http://sourceware.org/ftp/lvm2/LVM2.2.03.15.tgz' μ=Configure flags=($dirflags 'disable-static')}
openssh=(){tag=V_8_8 src=gh:%s/%s-portable μ=Autotools flags=('disable-static')}
dbus=(){tag=dbus-1.13.22 src=freedesktop:dbus/%s μ=CMake flags=('with-systemduserunitdir=no')}

# connman < libnftnl libmnl
libmnl=(){tag=1.0.4 src=netfilter:%s/%s-$tag.tar.bz2 μ=Configure flags=$dirflags}
libnftnl=(){tag=1.2.1 src=netfilter:%s/%s-$tag.tar.bz2 μ=Configure flags=$dirflags}
iptables=(){tag=1.8.7 src=netfilter:%s/%s-$tag.tar.bz2 μ=Configure flags=($dirflags 'enable-shared')}
nettle=(){tag=3.7 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'enable-shared')}
gnutls=(){src='http://www.gnupg.org/ftp/gcrypt/gnutls/v3.6/gnutls-3.6.16.tar.xz' μ=Configure flags=('with-included-libtasn1' 'without-p11-kit' 'enable-shared' $dirflags)}
# connman needs -lncurses
connman=(){tag=1.41 src=kernel:network/%s/%s μ=Autotools flags=('with-systemdunitdir=no')}


# efibootmgr
mandoc=(){src='https://mandoc.bsd.lv/snapshots/mandoc-1.14.6.tar.gz' μ=Configure}
efivar=(){tag=38 src=gh:rhboot/efivar μ=GMake}
efibootmgr=(){tag=main src=gh:rhboot/efibootmgr μ=GMake}


#############
# GNU Extra #
#############
gperf=(){tag=3.1 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
mpc=(){tag=1.2.1 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
#libiconv=(){tag=1.16 src=gnu:%s-$tag.tar.gz μ=Configure flags=($dirflags 'with-pic=no' 'enable-static=yes' 'enable-shared=no' 'enable-relocatable')}
gdb=(){tag=11.1 src=gnu:%s-$tag.tar.xz μ=Autotools flags=($dirflags 'with-guile=no' 'with-system-readline' 'with-python=no')}
guile=(){tag=3.0.7 src=gnu:%s-$tag.tar.gz μ=Configure flags=$dirflags}
