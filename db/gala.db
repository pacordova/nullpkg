#!/usr/bin/env rc

#vala
graphviz(){tag=2.49.2 src=gl:%s/%s μ=CMake}
vala(){src=download.gnome.org/sources/vala/0.54/vala-0.54.2.tar.xz μ=Configure}

# GALA STUFF
############
#optional?
accountsservice(){tag=0.6.55 src=freedesktop:accountsservice/%s}
gnome-backgrounds(){tag=41.0 src=gnome:%s μ=Meson}
