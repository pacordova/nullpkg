#gnome-color-manager(){src=gnome:%s μ=Meson flags=('tests=false')}
#stylesheet(){tag=6.1.0 src=gh:elementary/%s μ=Meson}
#clutter-gtk(){tag=1.8.4 src=gnome:%s μ=Meson}
#clutter-gst(){tag=3.0.27 src=gnome:%s μ=Autotools}

#colors (hard req according to lfs)
libgusb(){tag=0.3.7 src=gh:hughsie/%s μ=Meson}
colord(){tag=1.4.5 src=gh:hughsie/%s}

#gnome-settings-daemon
geocode-glib(){tag=3.26.2 src=gnome:%s μ=Meson}
libgweather(){tag=40.0 src=gnome:%s μ=Meson}
geoclue(){tag=2.5.7 src=freedesktop:%s/%s μ=Meson flags=('gtk-doc' '3g-source' 'cdma-source' 'modem-gps-source' 'demo-agent' 'nmea-source')^'=false'}
gnome-settings-daemon(){tag=41.0 src=gnome:%s μ=Meson flags=('systemd' 'cups' 'wwan')^'=false'}

#plank
gnome-common(){tag=3.18.0 src=gnome:%s μ=Autotools}
libgtop(){src=gnome:%s μ=Autotools flags=('disable-gtk-doc' 'without-examples')}
bamf(){tag=0.5.5 src=git.launchpad.net/%s μ=Autotools}
gnome-menus(){tag=3.36.0 src=gnome:%s μ=Autotools}
granite(){tag=6.1.2 src=gh:elementary/%s μ=Meson}
plank(){src=gh:elementary/dock μ=Meson flags=('enable-apport=false' 'enable-dbusmenu=no')}
#plank(){tag=0.11.89 src=git.launchpad.net/plank μ=Autotools flags=('disable-nls')}

#clutter
#cogl(){tag=1.22.8 src=gnome:%s μ=Autotools flags=('enable-wayland-egl-platform=yes')}
