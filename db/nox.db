#!/bin/rc


#########
# Langs #
#########
R=(){src='http://cran.r-project.org/src/base/R-4/R-4.2.0.tar.gz' μ=Configure flags=('with-blas=-lopenblas' 'disable-java' 'enable-R-shlib' 'without-recommended-packages' 'without-ICU' 'disable-nls')}

########
# misc #
########
firejail=(){tag=0.9.68 src=gh:netblue30/%s μ=Autotools}
gdb=(){tag=11.1 src=gnu:%s-$tag.tar.xz μ=Autotools flags=($dirflags 'with-guile=no' 'with-system-readline' 'with-python=no')}
ghostscript=(){tag=ghostpdl-9.55.0 src=gh:ArtifexSoftware/ghostpdl μ=Autotools}
imagemagick=(){tag=7.1.0-25 src=https://www.imagemagick.org/download/releases/ImageMagick-$tag.tar.xz μ=Configure flags=($dirflags 'disable-static' 'enable-hdri' 'with-modules')}
optipng=(){src='http://prdownloads.sourceforge.net/optipng/optipng-0.7.7.tar.gz' μ=Configure}
pngquant=(){tag=2.17.0 src=gh:kornelski/%s μ=Cargo}
rg=(){tag=13.0.0 src=gh:BurntSushi/ripgrep μ=Cargo}
