######
# QT #
######
qtbase=(){tag=kde/5.15 src=qt:%s.git μ=Configure flags=('extprefix='$destdir/$PREFIX 'libdir='$LIBDIR 'archdatadir='$LIBDIR/qt 'datadir='$PREFIX/share/qt 'docdir='$PREFIX/share/doc/qt 'opensource' 'confirm-license' 'optimize-size' 'nomake=examples' 'nomake=tests')}
qtsvg=(){tag=kde/5.15 src=qt:%s.git μ=QMake}
qttools=(){tag=kde/5.15 src=qt:%s.git μ=QMake}
qtx11extras=(){tag=kde/5.15 src=qt:%s.git μ=QMake}
qtdeclarative=(){tag=kde/5.15 src=qt:%s.git μ=QMake}

# keepassxc
libqrencode=(){tag=v4.1.1 src=gh:fukuchi/%s μ=CMake flags=('BUILD_SHARED_LIBS=YES')}
keepassxc=(){tag=2.7.1 src=gh:keepassxreboot/%s μ=CMake flags=('WITH_XC_DOCS=OFF' 'WITH_APP_BUNDLE=OFF')}
